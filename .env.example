PORT=8080

DB_ENABLED=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=finance_db
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m

AUTH_BOOTSTRAP_NAME=Owner
AUTH_BOOTSTRAP_EMAIL=owner@example.com
AUTH_BOOTSTRAP_PASSWORD=supersecret123
AUTH_JWT_SECRET=change-this-to-a-long-random-secret
AUTH_ISSUER=finance-backend
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
